{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "den-mond-anstreben",
  "compatibility_date": "2026-06-13",
  "observability": {
    "enabled": true
  },
  "main": "@tanstack/react-start/server-entry",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  }
}
